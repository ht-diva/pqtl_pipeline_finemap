rule run_cojo:
    input:
        gwas=get_sumstats,
        loci=ws_path("break/{seqid}_loci.tsv"),
    output:
        odir=ws_path("cojo/{seqid}/"),
        #log=ws_path("logs/cojo/{seqid}.log"),
    conda:
        "envs/r_environment.yml"
    params:
        codes   = config.get("path_code"),
        geno    = config.get("path_geno"),
        ofile   = ws_path("cojo/{seqid}"),
        mapping = config.get("path_mapping"),
        ppp     = config.get('thresholds').get('ppp'),
        p3      = config.get('thresholds').get('p3'),
        p4      = config.get('thresholds').get('p4'),
        maf     = config.get('thresholds').get('maf')
    log:
        ws_path("logs/cojo/{seqid}.log"),
    resources:
        mem_mb=16000, runtime=120,
    shell:
        """
        Rscript=`ls /conda-envs/*/bin/Rscript`;
        $Rscript workflow/scripts/s04_cojo_finemapping.R  \
            --pipeline_path   {params.codes}  \
            --dataset_aligned {input.gwas}  \
            --mapping  {params.mapping}  \
            --study_id {params.ofile}  \
            --chr   3 \
            --start 26518721  \
            --end   26742123  \
            --bfile {params.geno}  \
            --cs_thresh {params.ppp}  \
            --p_thresh3 {params.p3}  \
            --p_thresh4 {params.p4}  \
            --maf       {params.maf}  \
            --outdir {output.odir}  \
            --phenotype_id full  \
            --nf_hcoloc_v no_nf  2>> {log}
        """

